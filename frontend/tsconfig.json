{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "strict": false,
    "types": ["node", "react", "react-dom"]
  },
  "include": [
    "src/App.jsx",
    "src/lib/**/*.js",
    "src/hooks/useAssetDetail.js",
    "src/hooks/useBootstrap.js",
    "src/hooks/useGovernanceGlossaryTerm.js",
    "src/hooks/useGovernanceSummary.js",
    "src/hooks/useRuntimeStatus.js",
    "src/components/AppFrame.jsx",
    "src/components/DiscoveryWorkspace.jsx",
    "src/components/EntityWorkspace.jsx",
    "src/components/GovernanceWorkspace.jsx",
    "src/components/LineageWorkspace.jsx",
    "src/types/**/*.d.ts",
    "vite.config.js"
  ]
}
