{
  "name": "atlas-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "lint": "eslint src vite.config.js",
    "test": "NODE_OPTIONS=--no-experimental-webstorage node --no-experimental-webstorage ./node_modules/vitest/vitest.mjs run",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "build": "vite build && node scripts/write_build_manifest.mjs",
    "prewarm:demo": "node scripts/atlas_demo_prewarm.mjs",
    "smoke:deployed": "node scripts/atlas_deployed_smoke.mjs",
    "screenshots:phase2": "node scripts/phase2_screenshot_pack.mjs",
    "qa:deployed": "node scripts/atlas_comprehensive_qa.mjs",
    "identity:deployed": "node scripts/atlas_structural_identity.mjs",
    "northstar:audit-contract": "python3 ../scripts/check_northstar_audit_contract.py",
    "preview": "vite preview --host 0.0.0.0 --port 4173"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.90.5",
    "@xyflow/react": "^12.3.5",
    "dagre": "^0.8.5",
    "playwright": "^1.58.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.1",
    "topojson-client": "^3.1.0",
    "world-atlas": "^2.0.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.1",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^22.15.21",
    "@types/react": "^18.3.24",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.3.1",
    "eslint": "^9.25.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-unused-imports": "^4.1.4",
    "globals": "^16.0.0",
    "jsdom": "^26.1.0",
    "typescript": "^5.8.3",
    "vite": "^5.4.8",
    "vitest": "^3.2.4"
  }
}
